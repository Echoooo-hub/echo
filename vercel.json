{
  "rewrites": [
    {
      "source": "/个人照片/(.*)",
      "destination": "/个人照片/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/个人照片/(.*)\\.(jpg|jpeg|png|gif|webp)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/$2"
        }
      ]
    }
  ]
}